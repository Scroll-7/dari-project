rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──────────────────────────────────────────────────────
    // Any authenticated user can read any user profile (needed for search + chat headers)
    // Only the owner can write their own profile
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Roommate posts ────────────────────────────────────────────────────────
    // Any authenticated user can read; only the author can write
    match /roommatePosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // ── Conversations collection ──────────────────────────────────────────────
    // A user can only read/write a conversation they are a participant in
    match /conversations/{convId} {
      allow read: if request.auth != null &&
        (resource == null || request.auth.uid in resource.data.participants);
      allow update, delete: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // Allow creating a conversation if the current user is one of the participants
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      // ── Messages sub-collection ───────────────────────────────────────────
      // Same rule: only participants can read/write messages
      match /messages/{msgId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }
  }
}
